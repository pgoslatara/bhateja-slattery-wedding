---
import '../styles/global.css';
import { Image } from 'astro:assets';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { type Locale } from '../i18n/strings';
import siteBackground from '../assets/motifs/hero-mustard-field-couple.jpg';
import amsterdamFrieze from '../assets/motifs/amsterdam-frieze.svg?raw';

interface Props { lang: Locale; title?: string }
const { lang, title } = Astro.props;
const pageTitle = title ? `${title} · Apeksha & Padraic` : 'Apeksha & Padraic';
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL ?? '/' }}>
      (function () {
        try {
          var stored = localStorage.getItem('wedding_lang');
          var browserLang = (navigator.language || 'en').toLowerCase();
          var preferred = stored || (browserLang.indexOf('hi') === 0 ? 'hi' : 'en');
          if (!stored) localStorage.setItem('wedding_lang', preferred);
          var path = location.pathname;
          var trimmedBase = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
          var rest = path.startsWith(trimmedBase) ? path.slice(trimmedBase.length) : path;
          var onHindi = rest === '/hi' || rest.indexOf('/hi/') === 0;
          if (preferred === 'hi' && !onHindi) {
            location.replace(trimmedBase + '/hi' + (rest === '/' ? '/' : rest));
          } else if (preferred === 'en' && onHindi) {
            location.replace(trimmedBase + (rest.replace(/^\/hi/, '') || '/'));
          }
        } catch (e) { /* fail open */ }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,400&family=Inter:wght@400;500;700&family=Noto+Sans+Devanagari:wght@400;500;700&family=Playfair+Display:wght@700&family=Tiro+Devanagari+Hindi&display=swap"
    />
  </head>
  <body>
    <div class="site-bg" aria-hidden="true">
      <Image
        src={siteBackground}
        alt=""
        width={2400}
        quality={80}
        loading="eager"
        decoding="async"
      />
    </div>
    <div class="site-frieze" aria-hidden="true" set:html={amsterdamFrieze}></div>
    <Header lang={lang} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style>
  /*
    Site-wide background: the painted couple-in-field anchored to the
    bottom of the viewport, fixed so it stays visible as the page scrolls.
    A cream gradient at the top of the image fades it into the body
    background so text scrolling over the upper portion stays readable.
  */
  .site-bg {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100vw;
    aspect-ratio: 21 / 9;
    max-height: 65vh;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .site-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }
  .site-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--color-bg) 0%,
      rgba(253, 245, 212, 0.85) 12%,
      rgba(253, 245, 212, 0.35) 30%,
      rgba(253, 245, 212, 0) 55%
    );
    pointer-events: none;
  }
  /* Body, header, main, footer all need to render *above* the fixed
     background — z-index makes them paint on the layer in front of it. */
  body > header,
  body > main,
  body > footer,
  body > .site-frieze {
    position: relative;
    z-index: 1;
  }
  /* Footer sits on top of the figures' feet area; give it a solid backing
     so its text is fully readable. */
  body > footer {
    background: var(--color-bg);
  }
  /*
    Amsterdam-themed scatter (windmills + bicycles) over the top third
    of each page. Inline-flow so it scrolls naturally with the page;
    a vertical mask gradient fades the lower portion so the motifs
    "thin out" as the eye travels down. Sits behind page content via
    negative margin — the header overlays the upper portion.
  */
  .site-frieze {
    width: 100%;
    height: 33vh;
    min-height: 240px;
    max-height: 420px;
    color: var(--color-accent);
    opacity: 0.7;
    overflow: hidden;
    pointer-events: none;
    /* Fade vertically: opaque at top, transparent at bottom */
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 25%, transparent 100%);
    mask-image: linear-gradient(180deg, black 0%, black 25%, transparent 100%);
    /* Negative bottom margin pulls the page content up over the lower
       (already-faded) portion of the scatter, so the frieze doesn't
       push the header down by a full third of the viewport. */
    margin-bottom: calc(-33vh + 60px);
  }
  .site-frieze :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
