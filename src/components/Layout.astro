---
import '../styles/global.css';
import { Image } from 'astro:assets';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { t, type Locale } from '../i18n/strings';
import siteBackground from '../assets/motifs/hero-mustard-field-couple.jpg';
import amsterdamFrieze from '../assets/motifs/amsterdam-frieze.svg?raw';

interface Props { lang: Locale; title?: string }
const { lang, title } = Astro.props;
const s = t(lang);
const pageTitle = title ? `${title} · Apeksha & Pádraic` : 'Apeksha & Pádraic';
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL ?? '/' }}>
      (function () {
        try {
          var stored = localStorage.getItem('wedding_lang');
          var browserLang = (navigator.language || 'en').toLowerCase();
          var preferred = stored || (browserLang.indexOf('hi') === 0 ? 'hi' : 'en');
          if (!stored) localStorage.setItem('wedding_lang', preferred);
          var path = location.pathname;
          var trimmedBase = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
          var rest = path.startsWith(trimmedBase) ? path.slice(trimmedBase.length) : path;
          var onHindi = rest === '/hi' || rest.indexOf('/hi/') === 0;
          if (preferred === 'hi' && !onHindi) {
            location.replace(trimmedBase + '/hi' + (rest === '/' ? '/' : rest));
          } else if (preferred === 'en' && onHindi) {
            location.replace(trimmedBase + (rest.replace(/^\/hi/, '') || '/'));
          }
        } catch (e) { /* fail open */ }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,400&family=Inter:wght@400;500;700&family=Noto+Sans+Devanagari:wght@400;500;700&family=Playfair+Display:wght@700&family=Tiro+Devanagari+Hindi&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">{s.a11y.skipToMain}</a>
    <div class="site-frieze" aria-hidden="true" set:html={amsterdamFrieze}></div>
    <script is:inline>
      // Randomise the symbol in each scatter slot on every page load,
      // then force exactly one slot to be the stroopwafel misfit.
      (function () {
        var uses = document.querySelectorAll('.site-frieze svg use');
        if (!uses.length) return;
        var symbols = ['#windmill', '#bicycle', '#sunglasses', '#remote', '#book', '#hurley'];
        for (var i = 0; i < uses.length; i++) {
          var sym = symbols[Math.floor(Math.random() * symbols.length)];
          uses[i].setAttribute('href', sym);
        }
        var pick = uses[Math.floor(Math.random() * uses.length)];
        pick.setAttribute('href', '#stroopwafel');
      })();
    </script>
    <Header lang={lang} currentPath={currentPath} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <script is:inline>
      // Deep-link UX: when the URL has a hash, open any matched <details>
      // and (re)trigger the highlight pulse. Also intercept clicks on
      // [data-anchor-link] so re-clicking the same anchor replays the
      // animation and clicking inside a <summary> doesn't toggle it.
      (function () {
        // Localise the aria-label on any auto-generated anchor link
        // (e.g. from rehype-autolink-headings, which can't read the
        // page's lang at build time).
        var lang = document.documentElement.lang || 'en';
        var copyLinkLabel = lang === 'hi'
          ? 'इस सेक्शन का लिंक कॉपी करें'
          : 'Copy link to this section';
        document.querySelectorAll('[data-anchor-link]').forEach(function (el) {
          if (!el.getAttribute('aria-label')) {
            el.setAttribute('aria-label', copyLinkLabel);
          }
        });
        function targetFromHash() {
          if (!location.hash) return null;
          try {
            return document.getElementById(decodeURIComponent(location.hash.slice(1)));
          } catch (e) { return null; }
        }
        function reveal(el) {
          if (!el) return;
          var details = el.closest && el.closest('details');
          if (details) details.open = true;
          if (el.tagName === 'DETAILS') el.open = true;
          // Replay the pulse by toggling a class on the next frame.
          el.classList.remove('anchor-flash');
          void el.offsetWidth;
          el.classList.add('anchor-flash');
          el.addEventListener('animationend', function once() {
            el.classList.remove('anchor-flash');
            el.removeEventListener('animationend', once);
          });
          requestAnimationFrame(function () {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        }
        // On page load: handle the initial hash (if any).
        window.addEventListener('load', function () {
          var el = targetFromHash();
          if (el) reveal(el);
        });
        // In-page hash changes (clicking another anchor link).
        window.addEventListener('hashchange', function () {
          var el = targetFromHash();
          if (el) reveal(el);
        });
        // Intercept anchor-link clicks: stop the summary toggle, update
        // the hash, copy the share URL to the clipboard if available.
        document.addEventListener('click', function (e) {
          var link = e.target && e.target.closest && e.target.closest('[data-anchor-link]');
          if (!link) return;
          e.preventDefault();
          e.stopPropagation();
          var href = link.getAttribute('href') || '';
          var id = href.indexOf('#') === 0 ? href.slice(1) : href;
          if (!id) return;
          var el = document.getElementById(id);
          if (!el) return;
          var fullUrl = location.origin + location.pathname + location.search + '#' + id;
          if (location.hash === '#' + id) {
            // Same target — replay manually since hashchange won't fire.
            reveal(el);
          } else {
            history.pushState(null, '', '#' + id);
            reveal(el);
          }
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(fullUrl).catch(function () { /* ignore */ });
          }
        });
      })();
    </script>
    <div class="site-bg" aria-hidden="true">
      <Image
        src={siteBackground}
        alt=""
        width={2400}
        quality={80}
        loading="eager"
        decoding="async"
      />
    </div>
    <Footer lang={lang} />
  </body>
</html>

<style>
  /*
    Skip-link: hidden off-screen until focused (e.g. by Tab on first
    page load), then anchored to the top-left so a keyboard user can
    activate it to jump past the header into <main>.
  */
  .skip-link {
    position: absolute;
    left: 0.5rem;
    top: 0.5rem;
    transform: translateY(-200%);
    background: var(--color-bg);
    color: var(--color-primary);
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    text-decoration: none;
    z-index: 100;
    transition: transform 0.15s ease;
  }
  .skip-link:focus {
    transform: translateY(0);
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  /* The main element is given tabindex="-1" so it can receive
     programmatic focus from the skip-link click — strip the focus
     ring it would otherwise show. */
  main:focus { outline: none; }
  /*
    Body is a flex column anchored to viewport height so that on short
    pages the painted couple block is pushed to the bottom of the viewport
    rather than floating mid-page; on long pages it simply sits at the
    end of the document, after content.
  */
  body {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  body > main { flex: 1 0 auto; }
  /*
    Site-wide painted couple block. In normal flow at the bottom of the
    body so that text content can never scroll over it. A short cream
    gradient softens the top edge against the page background.
  */
  .site-bg {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 9;
    max-height: 40vh;
    overflow: hidden;
    pointer-events: none;
  }
  .site-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }
  .site-bg::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 25%;
    background: linear-gradient(
      180deg,
      var(--color-bg) 0%,
      rgba(253, 245, 212, 0) 100%
    );
    pointer-events: none;
    z-index: 1;
  }
  /* Header and main keep z-index above the top frieze (z-index 1) so
     interactive elements aren't blocked by the decorative scatter. */
  body > header,
  body > main {
    position: relative;
    z-index: 2;
  }
  /*
    Amsterdam-themed scatter (windmills, bicycles, sunglasses, remotes,
    books, a hurley — and one hidden stroopwafel) over the upper portion of each
    page. Position-absolute so it doesn't take any layout space (the
    header sits on top of it visually) and so it can never block
    pointer events on the header even when overlapping. Sized in vh so
    it always stops well clear of the painted couple block at the foot
    of the page; a vertical mask gradient fades the lower portion of
    the scatter so the motifs "thin out" as the eye travels down.
    Scrolls with the page rather than fixed to the viewport (no
    `position: fixed`).
  */
  .site-frieze {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 58vh;
    min-height: 280px;
    max-height: 720px;
    color: var(--color-accent);
    opacity: 0.7;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
    /* Fade vertically: opaque at top, transparent at bottom */
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 20%, transparent 100%);
    mask-image: linear-gradient(180deg, black 0%, black 20%, transparent 100%);
  }
  .site-frieze :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
