---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../Layout.astro';
import { t, type Locale } from '../../i18n/strings';
import { localeUrl } from '../../i18n/urls';
import { siteSchema, type SiteConfig } from '../../content/config';
import yaml from 'js-yaml';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// Photo strip: every image in src/assets/home/ is picked up automatically.
// Drop new files in or remove them — no other changes needed.
const photoModules = import.meta.glob<ImageMetadata>(
  '../../assets/home/*.{jpeg,jpg,png,webp,avif}',
  { eager: true, import: 'default' }
);
const photos = Object.entries(photoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, img]) => img);
// Render the list twice so a -50% translate loops seamlessly.
const photoLoop = [...photos, ...photos];

interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);

// Astro 5 i18n routing strips locale dots from slugs (home.hi.md → slug "homehi"),
// making getEntry()'s slug-based lookup unreliable. Use getCollection + filter on
// the stable file id (e.g. "home.en.md") instead.
const pages = await getCollection('pages');
const entry = pages.find(p => p.id === `home.${lang}.md`);
if (!entry) throw new Error(`Missing pages/home.${lang}.md`);
const { Content } = await entry.render();

// Resolve relative to project root — import.meta.url points to compiled chunks during build.
const siteRaw = readFileSync(resolve(process.cwd(), 'src/content/site.yaml'), 'utf8');
const site = siteSchema.parse(yaml.load(siteRaw)) as SiteConfig;

// Format the wedding date in the active locale. Construct from components so
// the date isn't shifted by the local timezone interpretation of midnight UTC.
const [y, m, d] = site.weddingDate.split('-').map(Number);
const dateLine = new Intl.DateTimeFormat(lang === 'hi' ? 'hi-IN' : 'en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
}).format(new Date(y, m - 1, d));

// Countdown messages are picked client-side based on days-until-wedding.
// Pre-computed messages object passed via define:vars to the inline script.
const countdownMessages = s.home.countdown;
const weddingISO = site.weddingDate;
---
<Layout lang={lang} title={entry.data.title}>
  <section class="hero deep-link-target" id="welcome">
    <h1>
      <span>{site.coupleNames.partner1} &amp; {site.coupleNames.partner2}</span>
    </h1>
    <p class="date">{dateLine} · {s.home.locationDisplay}</p>
    <p class="countdown" data-countdown></p>
    {photos.length > 0 && (
      <div class="photo-strip" aria-hidden="true">
        <ul class="photo-track" style={`--photo-count: ${photos.length}`}>
          {photoLoop.map((img, i) => (
            <li class="photo-slide">
              <Image
                src={img}
                alt=""
                width={640}
                quality={75}
                loading={i < photos.length ? 'eager' : 'lazy'}
                decoding="async"
              />
            </li>
          ))}
        </ul>
      </div>
    )}
    <Content />
    <div class="cta-row">
      <a class="button" href={localeUrl(lang, '/rsvp/')}>{s.nav.rsvp}</a>
      <a class="button button-secondary" href={localeUrl(lang, '/schedule/')}>{s.nav.schedule}</a>
    </div>
  </section>
  <aside class="mood-board deep-link-target" id="mood-board" aria-label={s.home.moodBoard.title}>
    <h2>
      <span>{s.home.moodBoard.title}</span>
      <a
        class="anchor-link"
        href="#mood-board"
        aria-label={s.a11y.copyLink}
        data-anchor-link
      >#</a>
    </h2>
    <div class="mood-grid">
      <div class="mood-col">
        <h3>{s.home.moodBoard.apekshaLabel}</h3>
        <p>{s.home.moodBoard.apekshaBody}</p>
      </div>
      <div class="mood-col">
        <h3>{s.home.moodBoard.padraicLabel}</h3>
        <p>{s.home.moodBoard.padraicBody}</p>
      </div>
    </div>
  </aside>
</Layout>

<script is:inline define:vars={{ messages: countdownMessages, weddingISO }}>
  // Shuffle the photo strip on each page load. SSR emits the list twice for the
  // seamless -50% scroll loop; we shuffle the first half, then rebuild the
  // second half as clones in the same new order so the seam still lines up.
  (function () {
    var track = document.querySelector('.photo-track');
    if (!track) return;
    var slides = Array.prototype.slice.call(track.children);
    var half = slides.length / 2;
    if (!half || half !== Math.floor(half)) return;
    var firstHalf = slides.slice(0, half);
    for (var i = firstHalf.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = firstHalf[i];
      firstHalf[i] = firstHalf[j];
      firstHalf[j] = tmp;
    }
    track.replaceChildren();
    firstHalf.forEach(function (el) { track.appendChild(el); });
    firstHalf.forEach(function (el) { track.appendChild(el.cloneNode(true)); });
  })();

  (function () {
    var target = document.querySelector('[data-countdown]');
    if (!target) return;
    var parts = weddingISO.split('-').map(Number);
    var wedding = new Date(parts[0], parts[1] - 1, parts[2]);
    wedding.setHours(0, 0, 0, 0);
    var now = new Date();
    now.setHours(0, 0, 0, 0);
    var msPerDay = 1000 * 60 * 60 * 24;
    var days = Math.round((wedding.getTime() - now.getTime()) / msPerDay);

    var key, useN = false;
    if (days > 365)      { key = 'moreThanYear'; useN = true; }
    else if (days === 365) { key = 'oneYear'; }
    else if (days > 30)  { key = 'months';      useN = true; }
    else if (days === 30){ key = 'nervous'; }
    else if (days > 7)   { key = 'listMaking';  useN = true; }
    else if (days === 7) { key = 'weekOut'; }
    else if (days > 1)   { key = 'finalDays';   useN = true; }
    else if (days === 1) { key = 'tomorrow'; }
    else if (days === 0) { key = 'today'; }
    else                  { key = 'past'; }

    var message = messages[key] || '';
    if (useN) message = message.replace('{n}', String(days));
    target.textContent = message;
  })();
</script>

<style>
  .hero { text-align: center; padding: 2rem 0 3rem; }
  .hero :global(h1) {
    color: var(--color-primary-dark);
    text-shadow: 0 1px 2px rgba(253, 245, 212, 0.7);
    /* Scale to viewport so the full couple name fits on one line — and small
       enough at the top end that it doesn't overflow the 720px main container,
       which would shove the nowrap span off-centre. */
    font-size: clamp(1rem, 5vw, 2.25rem);
  }
  .hero :global(h1) span { white-space: nowrap; }
  .date {
    font-family: var(--font-heading);
    /* Scales between phone and desktop without competing with the h1 above. */
    font-size: clamp(1.25rem, 3.2vw, 1.65rem);
    color: var(--color-primary-dark);
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease, color 0.3s ease, letter-spacing 0.3s ease;
    cursor: default;
    display: inline-block;
  }
  .date:hover {
    transform: scale(1.04);
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }
  .countdown {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
    min-height: 1.4em;
  }
  .countdown:empty { margin: 0; min-height: 0; }
  .cta-row { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .button-secondary { background: var(--color-accent); color: var(--color-text); }
  .button-secondary:hover { background: var(--color-accent-light); }

  .mood-board {
    max-width: 40rem;
    margin: 2rem auto 0;
    padding: 1.25rem 1.5rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(253, 245, 212, 0.55);
  }
  .mood-board h2 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-primary-dark);
    margin: 0 0 1rem;
    text-align: center;
  }
  .mood-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 32rem) {
    .mood-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  }
  .mood-col h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-primary);
    margin: 0 0 0.35rem;
  }
  .mood-col p {
    margin: 0;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* Continuous photo strip. Track holds two copies of the list and animates
     from 0 to -50%, so the loop seam lands on identical content and is
     invisible. Per-slide width sets how many are visible at once. */
  .photo-strip {
    margin: 2rem auto 0;
    max-width: 60rem;
    overflow: hidden;
    /* Soft fade at the edges suggests the strip extends past the viewport. */
    -webkit-mask-image: linear-gradient(
      to right, transparent, #000 6%, #000 94%, transparent
    );
    mask-image: linear-gradient(
      to right, transparent, #000 6%, #000 94%, transparent
    );
  }
  .photo-track {
    display: flex;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
    width: max-content;
    animation: photo-strip-scroll 80s linear infinite;
  }
  .photo-strip:hover .photo-track,
  .photo-strip:focus-within .photo-track {
    animation-play-state: paused;
  }
  .photo-slide {
    flex: 0 0 auto;
    /* ~2.4 visible on phone, climbing to 5 on wider screens. */
    width: 38vw;
    aspect-ratio: 5 / 9;
    border-radius: 6px;
    overflow: hidden;
  }
  .photo-slide :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 32rem) {
    .photo-slide { width: 9rem; }
  }
  @media (min-width: 48rem) {
    .photo-slide { width: 10.5rem; }
  }
  @keyframes photo-strip-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .photo-track { animation: none; }
  }
</style>
