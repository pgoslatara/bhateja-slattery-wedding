---
import { getCollection } from 'astro:content';
import yaml from 'js-yaml';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import Layout from '../Layout.astro';
import type { Locale } from '../../i18n/strings';
import { t } from '../../i18n/strings';
import { anchorFromEntryId } from '../../lib/anchors';
import { siteSchema, type SiteConfig } from '../../content/config';

interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);

const siteRaw = readFileSync(resolve(process.cwd(), 'src/content/site.yaml'), 'utf8');
const site = siteSchema.parse(yaml.load(siteRaw)) as SiteConfig;

const instagramUrl = 'https://www.instagram.com/bigtreevillagurgaon';
const airbnbUrl = 'https://www.airbnb.co.in/rooms/1049870901643016416';

const all = await getCollection('schedule', e => e.id.endsWith(`.${lang}.md`));
const items = all.sort((a, b) => a.data.day - b.data.day || a.data.order - b.data.order);

const dayLabels: Record<1 | 2, { en: string; hi: string }> = {
  1: { en: '26 February 2027', hi: '26 फ़रवरी 2027' },
  2: { en: '27 February 2027', hi: '27 फ़रवरी 2027' }
};

const byDay = new Map<1 | 2, typeof items>();
for (const item of items) {
  const day = item.data.day;
  if (!byDay.has(day)) byDay.set(day, []);
  byDay.get(day)!.push(item);
}
const days = [...byDay.entries()].sort(([a], [b]) => a - b);
---
<Layout lang={lang} title={s.nav.schedule}>
  <h1>{s.nav.schedule}</h1>
  <article class="card venue-card deep-link-target" id="venue">
    <h2>{lang === 'en' ? 'The venue' : 'स्थल'}</h2>
    {lang === 'en' ? (
      <>
        <p>
          Both days take place at <strong>{site.venue.name}</strong> (also listed as <em>Hideaway by Big Tree</em>), a private farmhouse in <strong>Bhondsi</strong>, on the southern edge of Gurgaon. It sits on a leafy one-acre estate.
        </p>
        <p>
          For a preview of the grounds, see the venue's <a href={instagramUrl} target="_blank" rel="noopener">Instagram</a> or the <a href={airbnbUrl} target="_blank" rel="noopener">Airbnb listing</a>. A precise address and map pin will be shared closer to the date.
        </p>
      </>
    ) : (
      <>
        <p>
          दोनों दिन के कार्यक्रम <strong>{site.venue.name}</strong> (जिसे <em>Hideaway by Big Tree</em> भी कहा जाता है) में होंगे — गुड़गांव के दक्षिणी छोर पर <strong>भोंडसी</strong> में एक प्राइवेट फ़ार्महाउस। यह लगभग एक एकड़ के हरे-भरे परिसर में फैला है।
        </p>
        <p>
          स्थल की झलक देखने के लिए वेन्यू का <a href={instagramUrl} target="_blank" rel="noopener">Instagram</a> या <a href={airbnbUrl} target="_blank" rel="noopener">Airbnb listing</a> देखें। सटीक पता और मैप पिन शादी की तारीख़ के नज़दीक साझा कर दिया जाएगा।
        </p>
      </>
    )}
  </article>
  <div class="days">
    {days.map(([day, dayItems]) => (
      <section>
        <h2>{dayLabels[day][lang]}</h2>
        {dayItems.map(async (entry) => {
          const { Content } = await entry.render();
          const anchorId = anchorFromEntryId(entry.id);
          return (
            <article class="card schedule-event deep-link-target" id={anchorId}>
              <header>
                <h3>
                  <span>{entry.data.name}</span>
                  <a
                    class="anchor-link"
                    href={`#${anchorId}`}
                    aria-label={s.a11y.copyLink}
                    data-anchor-link
                  >#</a>
                </h3>
                <p class="time">
                  {entry.data.startTime}
                  {entry.data.endTime && entry.data.endTime !== entry.data.startTime ? ` – ${entry.data.endTime}` : ''}
                </p>
                {entry.data.location && <p class="subtitle">{entry.data.location}</p>}
                {entry.data.dressCode && <p class="subtitle"><strong>{lang === 'en' ? 'Dress code' : 'ड्रेस कोड'}:</strong> {entry.data.dressCode}</p>}
              </header>
              <Content />
            </article>
          );
        })}
      </section>
    ))}
  </div>
</Layout>

<style>
  .venue-card { margin-bottom: 2rem; }
  .venue-card h2 { margin-top: 0; }
  .days { display: grid; gap: 2rem; }
  .schedule-event { margin-bottom: 1rem; }
  .schedule-event .time { font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-primary); margin: 0 0 0.25rem; }
  .schedule-event h3 { display: flex; align-items: baseline; gap: 0.5rem; }
  .schedule-event h3 > span { flex: 1 1 auto; }
</style>
